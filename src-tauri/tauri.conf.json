{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harushion",
  "version": "0.1.1",
  "identifier": "com.love-rox.harushion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Harushion",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCNEZBNERGMDMyMzFFMjMKUldRakhpTUQzNlJQaTdBQi9tQ3BnbUFINWhlcG4yeUwyRWpTR3BQSENpbXR4TEJRbSt2emFrUjkK",
      "endpoints": ["https://github.com/Love-Rox/Harushion/releases/latest/download/latest.json"]
    }
  }
}
